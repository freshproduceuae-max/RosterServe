{
  "name": "rosterserve-workspace",
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @rosterserve/web",
    "build": "npm run build --workspace @rosterserve/web",
    "lint": "npm run lint --workspace @rosterserve/web",
    "typecheck": "npm run typecheck --workspace @rosterserve/web"
  }
}
